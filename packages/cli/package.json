{
  "name": "@felixgeelhaar/glossa-cli",
  "version": "0.1.0",
  "description": "Build-time CLI for Glossa: init / scan / pull / push.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "glossa": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@felixgeelhaar/glossa-sdk": "workspace:*",
    "ignore": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "author": "Felix Geelhaar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixgeelhaar/glossa.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "i18n",
    "translation",
    "cli",
    "glossa"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://github.com/felixgeelhaar/glossa/tree/main/packages/cli#readme",
  "bugs": "https://github.com/felixgeelhaar/glossa/issues"
}
