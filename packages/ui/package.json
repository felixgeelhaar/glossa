{
  "name": "@glossa/ui",
  "version": "0.0.0",
  "description": "Glossa design system — utilitarian Lit primitives + design tokens. Used by the admin SPA and any consumer surface embedding glossa.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": [
    "dist",
    "src/tokens.css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && cp src/tokens.css dist/tokens.css",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "format": "prettier --write src"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "author": "Felix Geelhaar",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
